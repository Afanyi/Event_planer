{
  "name": "events-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "jest -c jest.config.ts --passWithNoTests",
    "test:watch": "jest -c jest.config.ts --watch",
    "test:unit": "jest -c jest.config.ts --runInBand",
    "test:int": "jest -c jest.int.config.ts --runInBand",
    "test:int:watch": "jest -c jest.int.config.ts --watch",
    "test:ci": "npm run test:unit && npm run test:int"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.6.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.21",
    "@types/node-fetch": "^2.6.13",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "mongodb-memory-server": "^10.2.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "jest-junit": {
    "outputDirectory": "reports",
    "outputName": "junit.xml"
  }
}
